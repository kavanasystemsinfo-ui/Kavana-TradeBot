# KAVANA Trading Bot — Plantilla de configuracion
# Copia este archivo a .env y rellena los valores reales.
# El .env NUNCA se sube al repositorio (ver .gitignore).

# Capital y simbolos
INITIAL_CAPITAL=1000
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,ADA/USDT,XRP/USDT
TIMEFRAME=5m
LEVERAGE=10

# Gestion de riesgo
RISK_PER_TRADE_PCT=1.0
ATR_MULTIPLIER=2.0
KELLY_FRACTION=0.25
DAILY_LOSS_LIMIT=5.0

# Filtro de tendencia VWAP (calibrado con datos reales KuCoin, ~0.15%)
TREND_STRENGTH=0.0015

# Exchange (KuCoin — lectura OHLCV)
EXCHANGE_PLATFORM=kucoin
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Notificaciones Telegram
TELEGRAM_BOT_TOKEN=

# Webhook / Google Sheets (opcional)
GOOGLE_SHEET_URL=
WEBHOOK_URL=

# IA (analisis contextual, opcional)
AISA_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Dashboards / DB
JWT_SECRET=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
